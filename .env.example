# Backend API (no trailing slash)
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Dev tip: use relative URL + Vite proxy to avoid CORS (see vite.config.js)
# VITE_API_BASE_URL=/api/v1

# Optional bearer token for protected admin routes
# VITE_API_TOKEN=

# Optional upload path (default: /upload)
# VITE_API_UPLOAD_PATH=/upload
